{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "shell",

            "command": "cmake --build build -- -j4"
        },

        {
            "label": "run",
            "type": "shell",

            "command": "./perekop.exe",
        },

        {
            "label": "config",
            "type": "shell",
            
            "command": "rm -r build; cmake -B build -DCMAKE_BUILD_TYPE=Release",
        }
    ]
}